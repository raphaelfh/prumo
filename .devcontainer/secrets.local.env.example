# Copy to .devcontainer/secrets.local.env and fill in. NEVER commit the filled file.
# Then run: .devcontainer/upload-secrets.sh

DATABASE_URL=postgresql://postgres.<project_ref>:<db_password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ENCRYPTION_KEY=

