# Prumo Backend - Render production template
# Copy these keys to Render service environment variables.

# =================== APP ===================
DEBUG=false
PROJECT_NAME=Prumo API
API_V1_PREFIX=/api/v1

# =================== CORS ===================
CORS_ORIGINS=https://prumo-alpha.vercel.app

# =================== SUPABASE ===================
SUPABASE_ENV=production
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =================== DATABASE ===================
# Runtime connection (pooler is fine for app traffic)
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
DIRECT_DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# =================== OPENAI ===================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# =================== SECURITY ===================
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# =================== RATE LIMITING ===================
RATE_LIMIT_PER_MINUTE=60

# =================== LANGSMITH (OPTIONAL) ===================
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT="your-langsmith-project"