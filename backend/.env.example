
# =================== APP ===================
PROJECT_NAME="Prumo API"
DEBUG=true
API_V1_PREFIX="/api/v1"

# =================== CORS ===================
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8080,http://127.0.0.1:8080"

# =================== SUPABASE ===================
SUPABASE_ENV="production"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# =================== DATABASE ===================
# Connection string do Postgres (Supabase ou local)
DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres"
# Para migrations remotas no Supabase, prefira o pooler com SSL:
# DATABASE_URL="postgresql://postgres.<project_ref>:<db_password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"
# Evite hosts no formato db.<project_ref>.supabase.co quando houver falha de DNS no ambiente local.

# =================== OPENAI ===================
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_DEFAULT_MODEL="gpt-4o-mini"

# =================== RATE LIMITING ===================
RATE_LIMIT_PER_MINUTE=60

# =================== SECURITY ===================
# Chave para criptografia de dados sensíveis (ex: Zotero API key)
# IMPORTANTE: Alterar em produção!
ENCRYPTION_KEY="review_hub_default_key_change_me_in_production"

# =================== LANGSMITH (OPCIONAL) ===================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="prumo"
