# =================== APP ===================
PROJECT_NAME="Review Hub API"
DEBUG=true
API_V1_PREFIX="/api/v1"

# =================== CORS ===================
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# =================== SUPABASE ===================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_ANON_KEY="your-anon-key"

# =================== DATABASE ===================
# Connection string do Postgres (Supabase ou local)
DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres"

# =================== OPENAI ===================
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_DEFAULT_MODEL="gpt-4o-mini"

# =================== RATE LIMITING ===================
RATE_LIMIT_PER_MINUTE=60

# =================== SECURITY ===================
# Chave para criptografia de dados sensíveis (ex: Zotero API key)
# IMPORTANTE: Alterar em produção!
ENCRYPTION_KEY="review_hub_default_key_change_me_in_production"

# =================== LANGSMITH (OPCIONAL) ===================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT="review-hub"

