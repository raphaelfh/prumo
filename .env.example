
# Supabase - URLs e Chaves Públicas
VITE_SUPABASE_ENV=local
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# FastAPI Backend
# ============================================
# URL do backend FastAPI
VITE_API_URL=http://localhost:8000

# Feature Flags (opcional, separado por vírgula)
# VITE_FEATURE_FLAGS=feature1,feature2,feature3

# Mock Data (opcional, para desenvolvimento)
# VITE_ENABLE_MOCK_DATA=false

# ============================================
# Edge Functions (Supabase) - Variáveis Privadas
# ============================================
# Essas variáveis são usadas apenas nas Edge Functions
# Não são expostas ao cliente
# Configure via Supabase Dashboard ou via .env ao rodar functions localmente

# Supabase Service (para Edge Functions)
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=your_supabase_anon_key_here
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OpenAI API (para funções de IA)
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Zotero Encryption Key (para criptografia de dados Zotero)
# ZOTERO_ENCRYPTION_KEY=your-secure-encryption-key-here-change-in-production

# ============================================
# Edge Functions - Configurações Opcionais
# ============================================
# Configurações avançadas para Edge Functions (valores padrão já definidos no código)

# Timeouts para LLM (em milissegundos)
# LLM_TIMEOUT_MS=60000
# LLM_TIMEOUT_GPT5_MS=100000

# Limites de tamanho de texto
# MAX_TEXT_LENGTH=50000
# MAX_TEXT_LENGTH_GPT5=100000

# Limite de tamanho de PDF (em MB)
# MAX_PDF_SIZE_MB=50

# Configurações de retry
# RETRY_MAX_ATTEMPTS=2
# RETRY_INITIAL_DELAY_MS=1000
# RETRY_PDF_INITIAL_DELAY_MS=1000

# Modelo padrão (para testes)
# MODEL=gpt-4o-mini
